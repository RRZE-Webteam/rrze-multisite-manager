{
  "name": "rrze-multisite-manager",
  "title": "RRZE Multisite Manager",
  "version": "1.1.7",
  "description": "Multisite-Management für WordPress",
  "main": "rrze-multisite-manager.php",
  "textdomain": "rrze-multisite-manager",
  "textDomain": "rrze-multisite-manager",
  "private": true,
  "scripts": {
    "readme": "node scripts/build-readme.js",
    "version:dev": "node scripts/build-version.js dev",
    "version:prod": "node scripts/build-version.js prod",
    "version:release": "node scripts/build-version.js release",
    "dev": "node scripts/build-assets.js dev && npm run version:dev && npm run readme",
    "build": "node scripts/build-assets.js prod",
    "prod": "node scripts/build-assets.js prod && npm run version:prod && npm run readme",
    "release": "node scripts/build-assets.js prod && npm run version:release && npm run readme",
    "watch": "node scripts/build-assets.js dev --watch"
  },
  "compatibility": {
    "wprequires": "6.9.4",
    "wptestedup": "7.0",
    "phprequires": "8.3"
  },
  "supports": {
    "email": "webmaster@fau.de"
  },
  "author": {
    "name": "RRZE-Webteam <webmaster@fau.de>",
    "url": "https://www.wp.rrze.fau.de"
  },
  "source": {
    "js": "./src/js/",
    "css": "./src/sass/"
  },
  "target": {
    "js": "./assets/js/",
    "css": "./assets/css/"
  },
  "license": "GNU General Public License v3",
  "licenseurl": "http://www.gnu.org/licenses/gpl-3.0.html",
  "tags": "Plugin, WordPress, Multisite, RRZE, FAU",
  "devDependencies": {
    "sass": "^1.94.2"
  },
  "dependencies": {
    "esbuild": "^0.27.3"
  }
}
